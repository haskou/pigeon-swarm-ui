{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DDD Subagent Output",
  "type": "object",
  "required": [
    "agent",
    "modules",
    "issues",
    "confidence"
  ],
  "properties": {
    "agent": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "uncertain"
      ]
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "files",
          "elements"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "elements": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}